@page "/dashboard/daily"
@inject RestaurantDashboard.Client.Services.DashboardService DashboardService

<h3>Dashboard Daily</h3>

<div class="mb-3">
    <label>From:</label>
    <input type="date" @bind="from" class="form-control" />
    <label class="mt-2">To:</label>
    <input type="date" @bind="to" class="form-control" />
    <button class="btn btn-primary mt-3" @onclick="Load">Load</button>
</div>

@if (daily != null)
{
    <table class="table table-bordered">
        <thead>
            <tr><th>Date</th><th>Sales</th><th>Expenses</th><th>Tips</th><th>Net Profit</th></tr>
        </thead>
        <tbody>
            @foreach (var item in daily)
            {
                <tr>
                    <td>@item.Date.ToShortDateString()</td>
                    <td>@item.Sales</td>
                    <td>@item.Expenses</td>
                    <td>@item.Tips</td>
                    <td>@item.NetProfit</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private DateTime? from;
    private DateTime? to;
    private List<RestaurantDashboard.Client.Models.DashboardDailyDto>? daily;

    private async Task Load()
    {
        daily = await DashboardService.GetDailyAsync(from, to);
    }
}